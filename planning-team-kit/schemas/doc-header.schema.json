{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "planning-team-kit document header",
  "type": "object",
  "required": [
    "doc_type",
    "title",
    "status",
    "owner",
    "audience",
    "last_updated",
    "version",
    "mode",
    "source_of_truth",
    "related_docs",
    "decision_required",
    "sensitivity",
    "approval_state"
  ],
  "properties": {
    "doc_type": {
      "enum": [
        "planning-context",
        "brief",
        "option-memo",
        "prd",
        "user-stories",
        "feature-spec",
        "qa-scenario",
        "metrics-brief",
        "stakeholder-brief"
      ]
    },
    "title": { "type": "string" },
    "status": { "enum": ["draft", "review", "approved", "archived"] },
    "owner": { "type": "string" },
    "audience": { "type": "string" },
    "last_updated": {
      "type": "string",
      "pattern": "^(YYYY-MM-DD|\\d{4}-\\d{2}-\\d{2})$"
    },
    "version": { "type": "string" },
    "mode": { "enum": ["lite", "standard", "full"] },
    "source_of_truth": { "type": "string" },
    "related_docs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "decision_required": { "type": "boolean" },
    "sensitivity": {
      "enum": ["public", "internal", "restricted", "highly-restricted"]
    },
    "approval_state": { "enum": ["draft", "needs_review", "approved"] }
  },
  "additionalProperties": false
}
